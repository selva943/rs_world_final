// ========== OFFERS API ==========

export const offersApi = {
  async getAll(): Promise<Offer[]> {
    try {
      const { data, error } = await supabase
        .from('offers')
        .select(`
          *,
          offer_products(product_id),
          offer_categories(category_id),
          offer_combos(product_id)
        `)
        .order('priority', { ascending: false });

      if (error) {
        console.error('Error fetching offers:', error);
        return [];
      }

      return (data || []).map((row: any) => ({
        id: row.id,
        offer_name: row.offer_name,
        offer_description: row.offer_description,
        offer_type: row.offer_type,
        discount_type: row.discount_type,
        discount_value: row.discount_value,
        min_quantity: row.min_quantity,
        max_discount: row.max_discount,
        start_date: row.start_date,
        end_date: row.end_date,
        priority: row.priority,
        status: row.status,
        banner_image_url: row.banner_image_url,
        created_at: row.created_at,
        updated_at: row.updated_at,
        products: row.offer_products?.map((op: any) => op.product_id) || [],
        categories: row.offer_categories?.map((oc: any) => oc.category_id) || [],
        combo_products: row.offer_combos?.map((oc: any) => oc.product_id) || [],
      }));
    } catch (error) {
      console.error('Error fetching offers:', error);
      return [];
    }
  },

  async getActive(): Promise<Offer[]> {
    try {
      const { data, error } = await supabase
        .from('offers')
        .select(`
          *,
          offer_products(product_id),
          offer_categories(category_id),
          offer_combos(product_id)
        `)
        .eq('status', 'active')
        .or('end_date.is.null,end_date.gt.now()')
        .order('priority', { ascending: false });

      if (error) {
        console.error('Error fetching active offers:', error);
        return [];
      }

      return (data || []).map((row: any) => ({
        id: row.id,
        offer_name: row.offer_name,
        offer_description: row.offer_description,
        offer_type: row.offer_type,
        discount_type: row.discount_type,
        discount_value: row.discount_value,
        min_quantity: row.min_quantity,
        max_discount: row.max_discount,
        start_date: row.start_date,
        end_date: row.end_date,
        priority: row.priority,
        status: row.status,
        banner_image_url: row.banner_image_url,
        created_at: row.created_at,
        updated_at: row.updated_at,
        products: row.offer_products?.map((op: any) => op.product_id) || [],
        categories: row.offer_categories?.map((oc: any) => oc.category_id) || [],
        combo_products: row.offer_combos?.map((oc: any) => oc.product_id) || [],
      }));
    } catch (error) {
      console.error('Error fetching active offers:', error);
      return [];
    }
  },

  async add(offer: Omit<Offer, 'id' | 'created_at'>): Promise<Offer | null> {
    try {
      console.log('Adding offer:', offer);
      
      const offerData = {
        offer_name: offer.offer_name,
        offer_description: offer.offer_description,
        offer_type: offer.offer_type,
        discount_type: offer.discount_type,
        discount_value: offer.discount_value,
        min_quantity: offer.min_quantity,
        max_discount: offer.max_discount,
        start_date: offer.start_date,
        end_date: offer.end_date,
        priority: offer.priority,
        status: offer.status,
        banner_image_url: offer.banner_image_url,
        updated_at: new Date().toISOString(),
      };

      console.log('Converted to DB format:', offerData);

      const { data, error } = await supabase
        .from('offers')
        .insert(offerData as any)
        .select()
        .single();

      if (error) {
        console.error('Error adding offer:', error);
        return null;
      }

      // Add related records if they exist
      if (offer.products && offer.products.length > 0) {
        await supabase
          .from('offer_products')
          .insert(
            offer.products.map(product_id => ({
              offer_id: data.id,
              product_id
            })) as any
          );
      }

      if (offer.categories && offer.categories.length > 0) {
        await supabase
          .from('offer_categories')
          .insert(
            offer.categories.map(category_id => ({
              offer_id: data.id,
              category_id
            })) as any
          );
      }

      if (offer.combo_products && offer.combo_products.length > 0) {
        await supabase
          .from('offer_combos')
          .insert(
            offer.combo_products.map(product_id => ({
              offer_id: data.id,
              product_id
            })) as any
          );
      }

      // Return the complete offer with relations
      return await this.getById(data.id);
    } catch (error) {
      console.error('Error adding offer:', error);
      return null;
    }
  },

  async getById(id: string): Promise<Offer | null> {
    try {
      const { data, error } = await supabase
        .from('offers')
        .select(`
          *,
          offer_products(product_id),
          offer_categories(category_id),
          offer_combos(product_id)
        `)
        .eq('id', id)
        .single();

      if (error) {
        console.error('Error fetching offer:', error);
        return null;
      }

      return {
        id: data.id,
        offer_name: data.offer_name,
        offer_description: data.offer_description,
        offer_type: data.offer_type,
        discount_type: data.discount_type,
        discount_value: data.discount_value,
        min_quantity: data.min_quantity,
        max_discount: data.max_discount,
        start_date: data.start_date,
        end_date: data.end_date,
        priority: data.priority,
        status: data.status,
        banner_image_url: data.banner_image_url,
        created_at: data.created_at,
        updated_at: data.updated_at,
        products: data.offer_products?.map((op: any) => op.product_id) || [],
        categories: data.offer_categories?.map((oc: any) => oc.category_id) || [],
        combo_products: data.offer_combos?.map((oc: any) => oc.product_id) || [],
      };
    } catch (error) {
      console.error('Error fetching offer:', error);
      return null;
    }
  },

  async update(id: string, offer: Partial<Offer>): Promise<boolean> {
    try {
      // Update main offer record
      const updateData: any = {
        updated_at: new Date().toISOString(),
      };

      if (offer.offer_name !== undefined) updateData.offer_name = offer.offer_name;
      if (offer.offer_description !== undefined) updateData.offer_description = offer.offer_description;
      if (offer.offer_type !== undefined) updateData.offer_type = offer.offer_type;
      if (offer.discount_type !== undefined) updateData.discount_type = offer.discount_type;
      if (offer.discount_value !== undefined) updateData.discount_value = offer.discount_value;
      if (offer.min_quantity !== undefined) updateData.min_quantity = offer.min_quantity;
      if (offer.max_discount !== undefined) updateData.max_discount = offer.max_discount;
      if (offer.start_date !== undefined) updateData.start_date = offer.start_date;
      if (offer.end_date !== undefined) updateData.end_date = offer.end_date;
      if (offer.priority !== undefined) updateData.priority = offer.priority;
      if (offer.status !== undefined) updateData.status = offer.status;
      if (offer.banner_image_url !== undefined) updateData.banner_image_url = offer.banner_image_url;

      const { error } = await supabase
        .from('offers')
        .update(updateData)
        .eq('id', id);

      if (error) {
        console.error('Error updating offer:', error);
        return false;
      }

      // Update related records
      if (offer.products !== undefined) {
        // Delete existing products
        await supabase.from('offer_products').delete().eq('offer_id', id);
        // Add new products
        if (offer.products.length > 0) {
          await supabase
            .from('offer_products')
            .insert(
              offer.products.map(product_id => ({
                offer_id: id,
                product_id
              }))
            );
        }
      }

      if (offer.categories !== undefined) {
        // Delete existing categories
        await supabase.from('offer_categories').delete().eq('offer_id', id);
        // Add new categories
        if (offer.categories.length > 0) {
          await supabase
            .from('offer_categories')
            .insert(
              offer.categories.map(category_id => ({
                offer_id: id,
                category_id
              }))
            );
        }
      }

      if (offer.combo_products !== undefined) {
        // Delete existing combo products
        await supabase.from('offer_combos').delete().eq('offer_id', id);
        // Add new combo products
        if (offer.combo_products.length > 0) {
          await supabase
            .from('offer_combos')
            .insert(
              offer.combo_products.map(product_id => ({
                offer_id: id,
                product_id
              }))
            );
        }
      }

      return true;
    } catch (error) {
      console.error('Error updating offer:', error);
      return false;
    }
  },

  async delete(id: string): Promise<boolean> {
    try {
      // Delete related records first
      await supabase.from('offer_products').delete().eq('offer_id', id);
      await supabase.from('offer_categories').delete().eq('offer_id', id);
      await supabase.from('offer_combos').delete().eq('offer_id', id);

      // Delete main offer record
      const { error } = await supabase
        .from('offers')
        .delete()
        .eq('id', id);

      if (error) {
        console.error('Error deleting offer:', error);
        return false;
      }

      return true;
    } catch (error) {
      console.error('Error deleting offer:', error);
      return false;
    }
  },
};

export const enquiriesApi = {
  async save(enquiry: Omit<Enquiry, 'id' | 'date'>): Promise<boolean> {
    try {
      // Map frontend type values to database values
      const dbEnquiry = {
        name: enquiry.name,
        phone: enquiry.phone,
        message: enquiry.message,
        type: enquiry.type.charAt(0).toUpperCase() + enquiry.type.slice(1).toLowerCase(), // Capitalize first letter
      };

      const { data, error } = await supabase
        .from('enquiries')
        .insert(dbEnquiry as any);

      if (error) {
        console.error('Error saving enquiry:', error);
        return false;
      }

      return true;
    } catch (error) {
      console.error('Error saving enquiry:', error);
      return false;
    }
  },

  async getAll(): Promise<Enquiry[]> {
    try {
      const { data, error } = await supabase
        .from('enquiries')
        .select('*')
        .order('created_at', { ascending: false });

      if (error) {
        console.error('Error fetching enquiries:', error);
        return [];
      }

      // Map database rows to frontend Enquiry type
      return ((data || []) as any[]).map(item => ({
        id: item.id,
        name: item.name,
        phone: item.phone,
        message: item.message,
        type: item.type.toLowerCase() as 'product' | 'rental' | 'general',
        date: item.created_at,
      }));
    } catch (error) {
      console.error('Error fetching enquiries:', error);
      return [];
    }
  },
};
